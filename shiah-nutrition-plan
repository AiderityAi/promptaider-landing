const M30=[{b:'Smoothie (banana, strawberry, chia)',l:'Chicken + rice + broccoli',d:'Feta pasta',s:'Apple + granola'},{b:'Yogurt + granola',l:'Salmon bowl',d:'Chicken bowl',s:'Smoothie'},{b:'Smoothie',l:'Chicken + rice + broccoli',d:'Sweet potato bowl',s:'Fruit'},{b:'Yogurt + granola',l:'Healthy fast food',d:'Feta pasta',s:'Granola bar'},{b:'Smoothie',l:'Chicken + rice + broccoli',d:'Salmon bowl',s:'Apple'},{b:'Yogurt + granola',l:'Chicken bowl',d:'Sweet potato bowl',s:'Smoothie'},{b:'Smoothie',l:'Salmon bowl',d:'Feta pasta',s:'Fruit + granola'},{b:'Yogurt + granola',l:'Chicken + rice + broccoli',d:'Chicken bowl',s:'Smoothie'},{b:'Smoothie',l:'Healthy fast food',d:'Salmon bowl',s:'Apple'},{b:'Yogurt + granola',l:'Chicken + rice + broccoli',d:'Feta pasta',s:'Granola'},{b:'Smoothie',l:'Salmon bowl',d:'Sweet potato bowl',s:'Fruit'},{b:'Yogurt + granola',l:'Chicken bowl',d:'Feta pasta',s:'Smoothie'},{b:'Smoothie',l:'Chicken + rice + broccoli',d:'Salmon bowl',s:'Apple + granola'},{b:'Yogurt + granola',l:'Healthy fast food',d:'Chicken bowl',s:'Fruit'},{b:'Smoothie',l:'Chicken + rice + broccoli',d:'Sweet potato bowl',s:'Smoothie'},{b:'Yogurt + granola',l:'Salmon bowl',d:'Feta pasta',s:'Granola'},{b:'Smoothie',l:'Chicken bowl',d:'Salmon bowl',s:'Fruit'},{b:'Yogurt + granola',l:'Chicken + rice + broccoli',d:'Sweet potato bowl',s:'Smoothie'},{b:'Smoothie',l:'Healthy fast food',d:'Feta pasta',s:'Apple'},{b:'Yogurt + granola',l:'Salmon bowl',d:'Chicken bowl',s:'Granola'},{b:'Smoothie',l:'Chicken + rice + broccoli',d:'Salmon bowl',s:'Fruit'},{b:'Yogurt + granola',l:'Chicken bowl',d:'Feta pasta',s:'Smoothie'},{b:'Smoothie',l:'Chicken + rice + broccoli',d:'Sweet potato bowl',s:'Apple'},{b:'Yogurt + granola',l:'Healthy fast food',d:'Salmon bowl',s:'Granola'},{b:'Smoothie',l:'Salmon bowl',d:'Feta pasta',s:'Fruit'},{b:'Yogurt + granola',l:'Chicken + rice + broccoli',d:'Chicken bowl',s:'Smoothie'},{b:'Smoothie',l:'Chicken bowl',d:'Sweet potato bowl',s:'Apple + granola'},{b:'Yogurt + granola',l:'Salmon bowl',d:'Feta pasta',s:'Fruit'},{b:'Smoothie',l:'Chicken + rice + broccoli',d:'Chicken bowl',s:'Smoothie'},{b:'Yogurt + granola',l:'Healthy fast food',d:'Sweet potato bowl',s:'Granola'}];
const BG=['var(--rose)','var(--lav)','var(--mint)','var(--peach)','var(--sky)'];
const BC=['var(--rose2)','var(--lav2)','var(--mint2)','var(--peach2)','var(--sky2)'];

function tkey(){return'day_'+new Date().toDateString()}
function ld(k,d){try{const v=localStorage.getItem(k);return v?JSON.parse(v):d}catch(e){return d}}
function sv(k,v){try{localStorage.setItem(k,JSON.stringify(v))}catch(e){}}
function showToast(){const t=document.getElementById('toast');t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000)}

function sw(id,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');el.classList.add('active');
  if(id==='history')rHist();
  if(id==='tracker')rTrk();
  if(id==='meals')rMeals('all');
  if(id==='grocery')lGroc();
}

function suppCk(el,num){
  const row=document.getElementById('sr-'+num);
  if(el.checked)row&&row.classList.add('sched-done');
  else row&&row.classList.remove('sched-done');
  updSupp();autoSave();
}

function updSupp(){
  const done=[1,2,3,4,5].filter(n=>{const e=document.getElementById('sup'+n);return e&&e.checked}).length;
  const oz=done*8;
  const bar=document.getElementById('supp-bar');if(bar)bar.style.width=Math.round(done/5*100)+'%';
  const lbl=document.getElementById('supp-lbl');if(lbl)lbl.textContent=done+' of 5 doses — '+oz+' of 40 oz completed';
  updSync();
}

function vitCk(el,rowId){
  const row=document.getElementById(rowId);
  row&&(el.checked?row.classList.add('done'):row.classList.remove('done'));
  autoSave();
}

function ck(el){
  const r=document.getElementById('ci-'+el.id);
  r&&(el.checked?r.classList.add('done'):r.classList.remove('done'));
  autoSave();
}

function uh(){
  const ids=['h1','h2','h3','h4','h5','h6'];
  const done=ids.filter(i=>{const e=document.getElementById(i);return e&&e.checked}).length;
  const totalOz=ids.reduce((a,i,idx)=>{const e=document.getElementById(i);return a+(e&&e.checked?HYD_OZ[idx]:0)},0);
  const bar=document.getElementById('hbar');if(bar)bar.style.width=Math.round(done/6*100)+'%';
  const lbl=document.getElementById('hlbl');if(lbl)lbl.textContent=done+' of 6 hydration goals · ~'+totalOz+' oz';
  updSync();autoSave();
}

function updSync(){
  const hydIds=['h1','h2','h3','h4','h5','h6'];
  const hydOz=hydIds.reduce((a,i,idx)=>{const e=document.getElementById(i);return a+(e&&e.checked?HYD_OZ[idx]:0)},0);
  const suppOz=[1,2,3,4,5].filter(n=>{const e=document.getElementById('sup'+n);return e&&e.checked}).length*8;
  const total=hydOz+suppOz;
  const msg=document.getElementById('hydro-sync-msg');
  if(msg&&total>0){msg.style.display='block';msg.textContent='Total intake today: ~'+total+' oz ('+hydOz+' oz water + '+suppOz+' oz supplement) — syncs to Weekly Tracker on save';}
  else if(msg)msg.style.display='none';
}

function selectFeel(group,val,cls){
  FEEL_GROUPS[group].forEach(v=>{
    const chip=document.getElementById('fc-'+group+'-'+v);const cb=document.getElementById('fe-'+group+'-'+v);
    if(chip)chip.className='feel-chip';if(cb)cb.checked=false;
  });
  const chip=document.getElementById('fc-'+group+'-'+val);const cb=document.getElementById('fe-'+group+'-'+val);
  if(chip)chip.className='feel-chip '+cls;if(cb)cb.checked=true;
  saveFeel();
}

function saveFeel(){
  const feels={};
  Object.keys(FEEL_GROUPS).forEach(g=>{
    FEEL_GROUPS[g].forEach(v=>{const cb=document.getElementById('fe-'+g+'-'+v);if(cb&&cb.checked)feels[g]=v;});
  });
  sv(tkey()+'_feel',feels);
}

function autoSave(){
  const st={};document.querySelectorAll('#today input[type=checkbox]').forEach(cb=>{st[cb.id]=cb.checked});sv(tkey()+'_c',st);
}

function calcTotalOz(st){
  const hydIds=['h1','h2','h3','h4','h5','h6'];
  const hydOz=hydIds.reduce((a,i,idx)=>a+(st[i]?HYD_OZ[idx]:0),0);
  const suppOz=[1,2,3,4,5].filter(n=>st['sup'+n]).length*8;
  return hydOz+suppOz;
}

function injectHydToTracker(dateStr,oz){
  const d=new Date(dateStr);
  const day=d.toLocaleDateString('en-US',{weekday:'short'});
  const trData=ld('trk_cur',{});
  trData['w'+day]=oz+' oz (auto)';
  sv('trk_cur',trData);
}

function loadToday(){
  const st=ld(tkey()+'_c',{});
  Object.keys(st).forEach(id=>{
    const el=document.getElementById(id);if(!el||!st[id])return;
    el.checked=true;
    if(id.startsWith('sup')){const n=parseInt(id.replace('sup',''));const row=document.getElementById('sr-'+n);row&&row.classList.add('sched-done');}
    else if(id.startsWith('vit')){const row=document.getElementById('vi-'+id.replace('vit',''));row&&row.classList.add('done');}
    else{const r=document.getElementById('ci-'+id);r&&r.classList.add('done');}
  });
  const feels=ld(tkey()+'_feel',{});
  Object.keys(feels).forEach(g=>{
    const v=feels[g];if(!v)return;
    const chip=document.getElementById('fc-'+g+'-'+v);const cb=document.getElementById('fe-'+g+'-'+v);
    if(chip&&CLS_MAP[g])chip.className='feel-chip '+CLS_MAP[g][v];
    if(cb)cb.checked=true;
  });
  const ta=document.getElementById('dnote');if(ta){ta.value=ld(tkey()+'_n','');ta.oninput=()=>sv(tkey()+'_n',ta.value);}
  uh();updSupp();
  const hist=ld('day_history',[]);const sp=document.getElementById('streak-pill');
  if(sp&&hist.length)sp.textContent=hist.length+' day'+(hist.length!==1?'s':'')+' logged';
}

function saveDay(){
  const st=ld(tkey()+'_c',{});const note=document.getElementById('dnote').value;
  const feels=ld(tkey()+'_feel',{});
  const all=['wind','sleep','wake','sup1','sup2','sup3','sup4','sup5','vit1','h1','h2','h3','h4','h5','h6','m1','m2','m3','m4'];
  const done=all.filter(i=>st[i]).length;
  const hd=['h1','h2','h3','h4','h5','h6'].filter(i=>st[i]).length;
  const totalOz=calcTotalOz(st);
  const entry={date:new Date().toDateString(),st,note,feels,done,total:all.length,hd,totalOz};
  const hist=ld('day_history',[]);const idx=hist.findIndex(h=>h.date===entry.date);
  if(idx>=0)hist[idx]=entry;else hist.unshift(entry);
  sv('day_history',hist);sv(tkey()+'_n',note);
  injectHydToTracker(entry.date,totalOz);
  showToast();
  const sp=document.getElementById('streak-pill');if(sp)sp.textContent=hist.length+' day'+(hist.length!==1?'s':'')+' logged';
}

function resetDay(){
  if(!confirm('Reset checkboxes for new day? All saved history and synced hydration data stay safe!'))return;
  document.querySelectorAll('#today input[type=checkbox]').forEach(cb=>cb.checked=false);
  document.querySelectorAll('#today .ci,.vit-item').forEach(r=>r.classList.remove('done'));
  document.querySelectorAll('.sched-tbl tbody tr').forEach(r=>r.classList.remove('sched-done'));
  document.querySelectorAll('.feel-chip').forEach(c=>c.className='feel-chip');
  const ta=document.getElementById('dnote');if(ta)ta.value='';
  uh();updSupp();
}

function rHist(){
  const hist=ld('day_history',[]);const el=document.getElementById('hist-list');
  if(!hist.length){el.innerHTML='<div style="font-size:13px;color:var(--text3);text-align:center;padding:2rem">No saved days yet!</div>';return}
  el.innerHTML=hist.map((h,i)=>`<div class="hi-item" onclick="showDet(${i})">
    <div class="hi-date">${h.date}</div>
    <div class="hi-meta">${h.done}/${h.total} tasks · ${h.hd}/6 water goals · ~${h.totalOz||0} oz total fluid</div>
    ${h.feels&&(h.feels.energy||h.feels.mood)?`<div class="hi-meta" style="color:var(--lav-txt);margin-top:2px">${h.feels.energy?'Energy: '+h.feels.energy:''}${h.feels.energy&&h.feels.mood?' · ':''}${h.feels.mood?'Mood: '+h.feels.mood:''}</div>`:''}
    ${h.note?`<div class="hi-note">"${h.note.substring(0,80)}${h.note.length>80?'...':''}"</div>`:''}
  </div>`).join('');
}

function showDet(i){
  const hist=ld('day_history',[]);const h=hist[i];
  document.getElementById('mod-title').textContent=h.date;
  const labels={wind:'Wind down',sleep:'Lights out',wake:'Wake up',sup1:'Supplement 8:00 AM (8oz)',sup2:'Supplement 8:30 AM (8oz)',sup3:'Supplement 9:00 AM (8oz)',sup4:'Supplement 9:30 AM (8oz)',sup5:'Supplement 10:00 AM (8oz)',vit1:'Daily vitamin / supplement',h1:'Morning water (16oz)',h2:'Water (~25oz)',h3:'Pre-cheer (16oz)',h4:'During cheer',h5:'Post-cheer (16oz)',h6:'Evening water (~18oz)',m1:'Breakfast',m2:'Lunch',m3:'Dinner',m4:'Snacks'};
  const ozRow=`<div class="drow"><div class="dk">Total fluid intake</div><div class="dv" style="color:var(--sky3)">~${h.totalOz||0} oz</div></div>`;
  const feelRow=`<div class="drow"><div class="dk">Energy · Mood</div><div class="dv" style="color:var(--lav3)">${h.feels&&h.feels.energy?h.feels.energy:'—'} · ${h.feels&&h.feels.mood?h.feels.mood:'—'}</div></div>`;
  const rows=Object.keys(labels).map(k=>`<div class="drow"><div class="dk">${labels[k]}</div><div class="dv" style="color:${h.st[k]?'var(--mint3)':'var(--text3)'}">${h.st[k]?'Done':'—'}</div></div>`).join('');
  document.getElementById('mod-body').innerHTML=ozRow+feelRow+rows+(h.note?`<div style="margin-top:12px;font-size:13px;color:var(--text2);font-style:italic;padding-top:12px;border-top:1px solid var(--border)">"${h.note}"</div>`:'');
  document.getElementById('mod-ov').classList.add('open');
}
function closeMod(e){if(e.target===document.getElementById('mod-ov'))closeModBtn()}
function closeModBtn(){document.getElementById('mod-ov').classList.remove('open')}

function rTrk(){
  const wk=ld('trk_cur',{});
  const wn=document.getElementById('wnote');if(wn){wn.value=ld('trk_wn','');wn.oninput=()=>sv('trk_wn',wn.value);}
  document.getElementById('trows').innerHTML=DAYS.map(d=>`<tr><td class="dn">${d}</td><td><input class="ti" id="tw${d}" value="${wk['w'+d]||''}" placeholder="—" oninput="autoT()"></td><td><input class="ti" id="tf${d}" value="${wk['f'+d]||''}" placeholder="—" oninput="autoT()"></td><td><input class="ti" id="tb${d}" value="${wk['b'+d]||''}" placeholder="—" oninput="autoT()"></td></tr>`).join('');
  rPW();
}
function autoT(){const d={};DAYS.forEach(day=>{['tw','tf','tb'].forEach(p=>{const el=document.getElementById(p+day);if(el)d[p.replace('t','')+day]=el.value});});sv('trk_cur',d);}
function saveTrk(){
  autoT();
  const entry={week:new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),data:ld('trk_cur',{}),note:ld('trk_wn','')};
  const past=ld('trk_hist',[]);const idx=past.findIndex(p=>p.week===entry.week);
  if(idx>=0)past[idx]=entry;else past.unshift(entry);sv('trk_hist',past);showToast();rPW();
}
function rPW(){
  const past=ld('trk_hist',[]);const el=document.getElementById('pwlist');
  if(!past.length){el.innerHTML='<div style="font-size:13px;color:var(--text3);text-align:center;padding:1rem">No past weeks yet.</div>';return}
  el.innerHTML=past.map(p=>`<div class="pw-item"><div class="pw-hdr">Week of ${p.week}</div><table class="pw-tbl">${DAYS.map(d=>`<tr><td>${d}</td><td>${p.data['w'+d]||'—'}</td><td>Fiber: ${p.data['f'+d]||'—'}</td><td>Bath: ${p.data['b'+d]||'—'}</td></tr>`).join('')}</table>${p.note?`<div style="font-size:12px;color:var(--text2);font-style:italic;margin-top:6px">"${p.note}"</div>`:''}</div>`).join('');
}
function rMeals(f){
  let days=M30.map((m,i)=>({...m,day:i+1,wk:Math.ceil((i+1)/7)}));
  if(f!=='all')days=days.filter(d=>d.wk===parseInt(f));
  document.getElementById('mlist').innerHTML=days.map((d,i)=>`<div class="meal-card" style="background:${BG[i%5]};border-color:${BC[i%5]}"><div class="md-num">Day ${d.day} &mdash; Week ${d.wk}</div><div class="mr"><span class="mt">Breakfast</span>${d.b}</div><div class="mr"><span class="mt">Lunch</span>${d.l}</div><div class="mr"><span class="mt">Dinner</span>${d.d}</div><div class="mr"><span class="mt">Snacks</span>${d.s}</div></div>`).join('');
}
function fwk(w,el){document.querySelectorAll('.filter-row .btn-sm').forEach(b=>b.classList.remove('af'));el.classList.add('af');rMeals(w);}
function lGroc(){const st=ld('groc',{});for(let i=1;i<=23;i++){const cb=document.getElementById('gc'+i);const row=document.getElementById('gi-'+i);if(cb&&st['gc'+i]){cb.checked=true;row&&row.classList.add('done');}}}
function gck(el,rid){const row=document.getElementById(rid);row&&(el.checked?row.classList.add('done'):row.classList.remove('done'));const st={};for(let i=1;i<=23;i++){const cb=document.getElementById('gc'+i);if(cb)st['gc'+i]=cb.checked;}sv('groc',st);}
function rstG(){for(let i=1;i<=23;i++){const cb=document.getElementById('gc'+i);const row=document.getElementById('gi-'+i);if(cb){cb.checked=false;row&&row.classList.remove('done');}}sv('groc',{});}

const dd=document.getElementById('hdr-date');
if(dd)dd.textContent=new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
loadToday();rMeals('all');
</script>
