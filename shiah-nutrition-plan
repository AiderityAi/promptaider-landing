<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shiah's Nutrition Plan</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --rose:#fde8ef;--rose2:#f9c4d6;--rose3:#d95a7a;--rose-txt:#7a2040;
  --mint:#e3f5ee;--mint2:#b4e4d0;--mint3:#3aaa80;--mint-txt:#174d38;
  --lav:#eeebff;--lav2:#cfc9f8;--lav3:#7260d8;--lav-txt:#362880;
  --peach:#fff0e6;--peach2:#ffd4b0;--peach3:#e07a3a;--peach-txt:#6e2d0e;
  --sky:#e6f4ff;--sky2:#b8dcf8;--sky3:#3a8fd4;--sky-txt:#0a3460;
  --lilac:#f5eeff;--lilac2:#e0ccff;--lilac3:#9b6fd4;--lilac-txt:#4a1f8a;
  --sage:#edf7ee;--sage2:#c6e8c8;--sage3:#4a9e52;--sage-txt:#1a4d1e;
  --cream:#fdfaf6;--white:#ffffff;
  --text:#2a2430;--text2:#6b6070;--text3:#ada2b8;
  --border:rgba(160,140,180,0.16);--border2:rgba(160,140,180,0.28);
  --r:10px;--rlg:16px;--rxl:24px;
  --shadow:0 2px 12px rgba(180,140,200,0.10);
}
body{font-family:'DM Sans',system-ui,sans-serif;background:var(--cream);color:var(--text);min-height:100vh;line-height:1.5}
.wrap{max-width:1100px;margin:0 auto;padding:1.5rem 1rem 3rem}
.hdr{background:var(--white);border:1px solid var(--border2);border-radius:var(--rxl);padding:1.5rem 2rem;margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;box-shadow:var(--shadow)}
.hdr h1{font-size:22px;font-weight:600;color:var(--text);letter-spacing:-0.02em}
.hdr p{font-size:13px;color:var(--text3);margin-top:2px}
.hdr-pills{display:flex;gap:8px;flex-wrap:wrap}
.pill{font-size:11px;font-weight:600;padding:5px 14px;border-radius:20px;letter-spacing:0.02em}
.pill-rose{background:var(--rose2);color:var(--rose-txt)}
.pill-mint{background:var(--mint2);color:var(--mint-txt)}
.pill-lav{background:var(--lav2);color:var(--lav-txt)}
.tabs-bar{background:var(--white);border:1px solid var(--border);border-radius:var(--rlg);padding:6px;margin-bottom:1.25rem;display:flex;gap:4px;flex-wrap:wrap;box-shadow:var(--shadow)}
.tab{padding:8px 18px;font-size:11px;font-weight:600;cursor:pointer;border:none;background:transparent;color:var(--text3);border-radius:var(--r);white-space:nowrap;letter-spacing:0.04em;text-transform:uppercase;transition:all 0.15s;font-family:inherit}
.tab:hover{background:var(--cream);color:var(--text)}
.tab.active{background:var(--rose3);color:#fff}
.sec{display:none}.sec.active{display:block}
.two{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem}
.three{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.25rem}
@media(max-width:800px){.two,.three{grid-template-columns:1fr}}
.card{background:var(--white);border:1px solid var(--border);border-radius:var(--rlg);padding:1.125rem 1.25rem;margin-bottom:1rem;box-shadow:var(--shadow)}
.card.rose{background:var(--rose);border-color:var(--rose2)}
.card.mint{background:var(--mint);border-color:var(--mint2)}
.card.lav{background:var(--lav);border-color:var(--lav2)}
.card.peach{background:var(--peach);border-color:var(--peach2)}
.card.sky{background:var(--sky);border-color:var(--sky2)}
.card.lilac{background:var(--lilac);border-color:var(--lilac2)}
.card.sage{background:var(--sage);border-color:var(--sage2)}
.ctitle{font-size:14px;font-weight:600;margin-bottom:10px}
.slabel{font-size:10px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--text3);margin:1.25rem 0 8px}
.slabel:first-child{margin-top:0}
.ci{display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)}
.ci:last-child{border-bottom:none;padding-bottom:0}
.ci input[type=checkbox]{width:17px;height:17px;margin-top:2px;cursor:pointer;flex-shrink:0;accent-color:var(--rose3)}
.ci.done label{color:var(--text3);text-decoration:line-through}
label{font-size:13px;color:var(--text);cursor:pointer;line-height:1.45}
.tl{font-size:11px;color:var(--text2);display:block;margin-top:1px}
.pb{height:6px;border-radius:3px;background:var(--rose2);margin:8px 0}
.pf{height:6px;border-radius:3px;background:var(--rose3);transition:width 0.4s}
.plbl{font-size:11px;color:var(--rose-txt);font-weight:500}
.badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 9px;border-radius:20px;margin-left:6px;letter-spacing:0.02em}
.b-rose{background:var(--rose2);color:var(--rose-txt)}
.b-mint{background:var(--mint2);color:var(--mint-txt)}
.b-lav{background:var(--lav2);color:var(--lav-txt)}
.b-peach{background:var(--peach2);color:var(--peach-txt)}
.b-sky{background:var(--sky2);color:var(--sky-txt)}
.b-lilac{background:var(--lilac2);color:var(--lilac-txt)}
.b-sage{background:var(--sage2);color:var(--sage-txt)}
textarea{width:100%;border:1.5px solid var(--border2);border-radius:var(--r);padding:10px;font-size:13px;font-family:inherit;color:var(--text);background:var(--white);resize:vertical;min-height:80px;margin-top:8px;outline:none}
textarea:focus{border-color:var(--rose3)}
textarea::placeholder{color:var(--text3)}
.btn-p{display:block;width:100%;padding:11px;border:none;border-radius:var(--rxl);background:var(--rose3);color:#fff;font-size:13px;font-weight:600;cursor:pointer;margin-top:10px;font-family:inherit;transition:opacity 0.15s}
.btn-p:hover{opacity:0.88}
.btn-s{display:block;width:100%;padding:10px;border:1.5px solid var(--border2);border-radius:var(--rxl);background:transparent;color:var(--text2);font-size:12px;cursor:pointer;margin-top:6px;font-family:inherit}
.btn-sm{padding:6px 14px;border:1.5px solid var(--border2);border-radius:20px;background:transparent;color:var(--text2);font-size:11px;font-weight:600;cursor:pointer;letter-spacing:0.03em;font-family:inherit;transition:all 0.15s}
.btn-sm:hover{background:var(--cream)}
.btn-sm.af{background:var(--rose3);color:#fff;border-color:var(--rose3)}
.filter-row{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:1rem}
/* SUPPLEMENT SCHEDULE */
.sched-tbl{width:100%;border-collapse:collapse}
.sched-tbl th{font-size:10px;font-weight:700;color:var(--lilac-txt);text-transform:uppercase;letter-spacing:0.05em;padding:7px 10px 7px 0;border-bottom:1px solid var(--lilac2);text-align:left}
.sched-tbl td{padding:8px 10px 8px 0;border-bottom:1px solid rgba(155,111,212,0.12);vertical-align:middle}
.sched-tbl tr:last-child td{border-bottom:none}
.sched-tbl tr.sched-done td:not(:last-child){opacity:0.45}
.sched-tbl tr.sched-done .sched-amt{text-decoration:line-through}
.sched-time{font-size:13px;font-weight:600;color:var(--lilac-txt);white-space:nowrap}
.sched-amt{font-size:13px;color:var(--text)}
.sched-cb{accent-color:var(--lilac3);width:17px;height:17px;cursor:pointer}
.suppl-pb{height:6px;border-radius:3px;background:var(--lilac2);margin:12px 0 4px}
.suppl-pf{height:6px;border-radius:3px;background:var(--lilac3);transition:width 0.4s}
/* VITAMIN */
.vit-item{display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)}
.vit-item:last-child{border-bottom:none;padding-bottom:0}
.vit-item input[type=checkbox]{width:17px;height:17px;margin-top:2px;cursor:pointer;flex-shrink:0;accent-color:var(--sage3)}
.vit-item.done label{color:var(--text3);text-decoration:line-through}
/* FEELING SECTION */
.feel-block{margin-bottom:14px}
.feel-block:last-of-type{margin-bottom:0}
.feel-title{font-size:12px;font-weight:600;color:var(--lav-txt);margin-bottom:8px;letter-spacing:0.01em}
.feel-opts{display:flex;gap:8px;flex-wrap:wrap}
.feel-chip{display:flex;align-items:center;gap:7px;padding:7px 14px;border-radius:20px;border:1.5px solid var(--border2);cursor:pointer;background:var(--white);transition:all 0.15s;font-size:13px;color:var(--text2)}
.feel-chip:hover{border-color:var(--lav3)}
.feel-chip input{width:15px;height:15px;cursor:pointer;flex-shrink:0}
.feel-chip.sel-high{background:var(--mint);border-color:var(--mint3);color:var(--mint-txt)}
.feel-chip.sel-high input{accent-color:var(--mint3)}
.feel-chip.sel-med{background:var(--peach);border-color:var(--peach3);color:var(--peach-txt)}
.feel-chip.sel-med input{accent-color:var(--peach3)}
.feel-chip.sel-low{background:var(--rose);border-color:var(--rose3);color:var(--rose-txt)}
.feel-chip.sel-low input{accent-color:var(--rose3)}
.feel-chip.sel-good{background:var(--mint);border-color:var(--mint3);color:var(--mint-txt)}
.feel-chip.sel-good input{accent-color:var(--mint3)}
.feel-chip.sel-ok{background:var(--peach);border-color:var(--peach3);color:var(--peach-txt)}
.feel-chip.sel-ok input{accent-color:var(--peach3)}
.feel-chip.sel-bad{background:var(--rose);border-color:var(--rose3);color:var(--rose-txt)}
.feel-chip.sel-bad input{accent-color:var(--rose3)}
.divider{height:1px;background:var(--border);margin:14px 0}
.hydro-sync{background:var(--mint);border:1px solid var(--mint2);border-radius:var(--r);padding:8px 12px;margin-top:8px;font-size:12px;color:var(--mint-txt);font-weight:500;display:none}
/* TRACKER */
.tr-tbl{width:100%;border-collapse:collapse}
.tr-tbl th{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.05em;padding:8px 8px 8px 0;border-bottom:1px solid var(--border2);text-align:left}
.tr-tbl td{padding:7px 6px 7px 0;border-bottom:1px solid var(--border)}
.tr-tbl tr:last-child td{border-bottom:none}
.tr-tbl .dn{font-size:13px;font-weight:600}
.ti{border:1.5px solid var(--border2);border-radius:8px;padding:6px 8px;font-size:12px;width:100%;background:var(--white);color:var(--text);font-family:inherit;outline:none}
.ti:focus{border-color:var(--rose3)}
/* HISTORY */
.hi-item{padding:10px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:opacity 0.15s}
.hi-item:hover{opacity:0.7}
.hi-item:last-child{border-bottom:none}
.hi-date{font-size:13px;font-weight:600}
.hi-meta{font-size:11px;color:var(--text2);margin-top:2px}
.hi-note{font-size:11px;color:var(--text3);margin-top:2px;font-style:italic}
/* MODAL */
.modal-ov{display:none;position:fixed;inset:0;background:rgba(60,20,50,0.35);z-index:200;align-items:center;justify-content:center}
.modal-ov.open{display:flex}
.modal{background:var(--white);border-radius:var(--rxl);padding:1.75rem;max-width:540px;width:calc(100% - 2rem);max-height:90vh;overflow-y:auto;box-shadow:0 8px 40px rgba(180,120,160,0.18)}
.modal-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem}
.modal-hdr h3{font-size:16px;font-weight:600}
.drow{display:flex;justify-content:space-between;font-size:13px;padding:5px 0;border-bottom:1px solid var(--border)}
.drow:last-child{border-bottom:none}
.dk{color:var(--text2)}.dv{font-weight:500}
/* MEALS */
.meal-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px}
.meal-card{border-radius:var(--rlg);padding:1rem;border:1px solid var(--border)}
.md-num{font-size:10px;font-weight:700;color:var(--lav-txt);letter-spacing:0.04em;text-transform:uppercase;margin-bottom:6px}
.mr{font-size:12px;color:var(--text2);margin-top:4px;display:flex;gap:8px;line-height:1.35}
.mt{font-size:10px;font-weight:600;color:var(--text3);min-width:52px;flex-shrink:0;padding-top:1px}
/* RECIPES */
.rstep{font-size:13px;padding:7px 0;border-bottom:1px solid var(--border);line-height:1.45}
.rstep:last-child{border-bottom:none}
.rstep span{font-size:10px;font-weight:700;color:var(--text3);display:block;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px}
/* GROCERY */
.gi{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--border)}
.gi:last-child{border-bottom:none}
.gi input{accent-color:var(--mint3);width:16px;height:16px;cursor:pointer;flex-shrink:0}
.gi.done label{text-decoration:line-through;color:var(--text3)}
/* FAST FOOD */
.ff-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1rem}
.ff-card{border-radius:var(--rlg);padding:1.125rem 1.25rem;border:1px solid var(--border)}
.ff-name{font-size:15px;font-weight:700;margin-bottom:10px}
.ff-order{font-size:13px;color:var(--text);margin-bottom:4px;display:flex;align-items:baseline;gap:8px;line-height:1.4}
.dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:5px;background:var(--mint3)}
.ff-tip{font-size:12px;color:var(--mint-txt);background:rgba(255,255,255,0.7);border-radius:8px;padding:7px 10px;margin-top:8px;line-height:1.45}
.ff-skip{font-size:12px;color:var(--rose-txt);background:rgba(255,255,255,0.7);border-radius:8px;padding:7px 10px;margin-top:5px;line-height:1.45}
.ff-rules{background:var(--peach);border:1px solid var(--peach2);border-radius:var(--rlg);padding:1.25rem;margin-top:1.25rem}
.ff-rules-title{font-size:14px;font-weight:700;color:var(--peach-txt);margin-bottom:10px}
.ff-rules-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px}
@media(max-width:600px){.ff-rules-grid{grid-template-columns:1fr}}
.rule-item{display:flex;align-items:baseline;gap:8px;font-size:13px;color:var(--text)}
/* PAST WEEKS */
.pw-item{padding:10px 0;border-bottom:1px solid var(--border)}
.pw-item:last-child{border-bottom:none}
.pw-hdr{font-size:13px;font-weight:600;margin-bottom:6px}
.pw-tbl{width:100%;border-collapse:collapse;font-size:12px}
.pw-tbl td{padding:2px 10px 2px 0;color:var(--text2)}
.pw-tbl td:first-child{font-weight:500;color:var(--text);width:40px}
.toast{position:fixed;bottom:28px;right:28px;background:var(--rose3);color:#fff;font-size:13px;font-weight:600;padding:10px 20px;border-radius:20px;opacity:0;transition:opacity 0.25s;pointer-events:none;z-index:300;box-shadow:0 4px 16px rgba(200,80,120,0.25)}
.toast.show{opacity:1}
</style>
</head>
<body>
<div class="wrap">

<div class="hdr">
  <div>
    <h1>Shiah's Nutrition Plan</h1>
    <p id="hdr-date"></p>
  </div>
  <div class="hdr-pills">
    <span class="pill pill-rose" id="streak-pill">Plan active</span>
    <span class="pill pill-mint">Cheer season</span>
    <span class="pill pill-lav">Recovery mode</span>
  </div>
</div>

<div class="tabs-bar">
  <button class="tab active" onclick="sw('today',this)">Today</button>
  <button class="tab" onclick="sw('fastfood',this)">Fast Food Guide</button>
  <button class="tab" onclick="sw('history',this)">History</button>
  <button class="tab" onclick="sw('tracker',this)">Weekly Tracker</button>
  <button class="tab" onclick="sw('meals',this)">30-Day Meals</button>
  <button class="tab" onclick="sw('grocery',this)">Grocery List</button>
  <button class="tab" onclick="sw('recipes',this)">Recipes</button>
</div>

<!-- TODAY -->
<div id="today" class="sec active">
  <div class="two">
    <div>
      <div class="slabel">Sleep schedule</div>
      <div class="card rose">
        <div class="ci" id="ci-wake"><input type="checkbox" id="wake" onchange="ck(this)"><label for="wake">Wake up<span class="tl">6:30–7:30 AM</span></label></div>
        <div class="ci" id="ci-wind"><input type="checkbox" id="wind" onchange="ck(this)"><label for="wind">Wind down<span class="tl">9:00 PM — screens off, dim lights</span></label></div>
        <div class="ci" id="ci-sleep"><input type="checkbox" id="sleep" onchange="ck(this)"><label for="sleep">Lights out<span class="tl">9:30–10:30 PM</span></label></div>
      </div>

      <div class="slabel">Supplement drinking <span class="badge b-lilac">40 oz total</span></div>
      <div class="card lilac">
        <div style="font-size:13px;color:var(--lilac-txt);font-weight:500;margin-bottom:12px">Every 30 min starting 8:00 AM — 8 oz per dose to reach 40 oz</div>
        <table class="sched-tbl">
          <thead><tr><th>Time</th><th>Amount</th><th>Done</th></tr></thead>
          <tbody>
            <tr id="sr-1"><td class="sched-time">8:00 AM</td><td><span class="sched-amt">8 oz — dose 1 of 5</span></td><td><input type="checkbox" class="sched-cb" id="sup1" onchange="suppCk(this,1)"></td></tr>
            <tr id="sr-2"><td class="sched-time">8:30 AM</td><td><span class="sched-amt">8 oz — dose 2 of 5</span></td><td><input type="checkbox" class="sched-cb" id="sup2" onchange="suppCk(this,2)"></td></tr>
            <tr id="sr-3"><td class="sched-time">9:00 AM</td><td><span class="sched-amt">8 oz — dose 3 of 5</span></td><td><input type="checkbox" class="sched-cb" id="sup3" onchange="suppCk(this,3)"></td></tr>
            <tr id="sr-4"><td class="sched-time">9:30 AM</td><td><span class="sched-amt">8 oz — dose 4 of 5</span></td><td><input type="checkbox" class="sched-cb" id="sup4" onchange="suppCk(this,4)"></td></tr>
            <tr id="sr-5"><td class="sched-time">10:00 AM</td><td><span class="sched-amt">8 oz — dose 5 of 5 (40 oz complete!)</span></td><td><input type="checkbox" class="sched-cb" id="sup5" onchange="suppCk(this,5)"></td></tr>
          </tbody>
        </table>
        <div class="suppl-pb"><div class="suppl-pf" id="supp-bar" style="width:0%"></div></div>
        <div style="font-size:12px;color:var(--lilac-txt);font-weight:500" id="supp-lbl">0 of 5 doses — 0 of 40 oz completed</div>
      </div>

      <div class="slabel">Supplement / Vitamin <span class="badge b-sage">after drinking</span></div>
      <div class="card sage">
        <div style="font-size:12px;color:var(--sage-txt);margin-bottom:10px">Take 1 dose after completing your supplement drinking schedule</div>
        <div class="vit-item" id="vi-1">
          <input type="checkbox" id="vit1" onchange="vitCk(this,'vi-1')">
          <label for="vit1">Daily vitamin / supplement<span class="tl">1 piece or dose — take after supplement drinking is complete</span></label>
        </div>
      </div>

      <div class="slabel">Meals</div>
      <div class="card mint">
        <div class="ci" id="ci-m1"><input type="checkbox" id="m1" onchange="ck(this)"><label for="m1">Breakfast<span class="tl">Smoothie or yogurt + granola</span></label></div>
        <div class="ci" id="ci-m2"><input type="checkbox" id="m2" onchange="ck(this)"><label for="m2">Lunch<span class="tl">Chicken + rice + broccoli or healthy fast food</span></label></div>
        <div class="ci" id="ci-m3"><input type="checkbox" id="m3" onchange="ck(this)"><label for="m3">Dinner<span class="tl">Feta pasta, salmon bowl, or chicken bowl</span></label></div>
        <div class="ci" id="ci-m4"><input type="checkbox" id="m4" onchange="ck(this)"><label for="m4">Snacks<span class="tl">Fruit, granola, or smoothie</span></label></div>
      </div>
    </div>

    <div>
      <div class="slabel">Hydration <span class="badge b-sky">80+ oz daily goal</span></div>
      <div class="card sky">
        <div class="ci" id="ci-h1"><input type="checkbox" id="h1" onchange="ck(this);uh()"><label for="h1">Morning water<span class="tl">16 oz Essentia or Eternal</span></label></div>
        <div class="ci" id="ci-h2"><input type="checkbox" id="h2" onchange="ck(this);uh()"><label for="h2">School water<span class="tl">20–30 oz</span></label></div>
        <div class="ci" id="ci-h3"><input type="checkbox" id="h3" onchange="ck(this);uh()"><label for="h3">Pre-cheer<span class="tl">16 oz Essentia</span></label></div>
        <div class="ci" id="ci-h4"><input type="checkbox" id="h4" onchange="ck(this);uh()"><label for="h4">During cheer<span class="tl">Liquid I.V. — Tue/Thu/Fri</span></label></div>
        <div class="ci" id="ci-h5"><input type="checkbox" id="h5" onchange="ck(this);uh()"><label for="h5">Post-cheer<span class="tl">16 oz Eternal</span></label></div>
        <div class="ci" id="ci-h6"><input type="checkbox" id="h6" onchange="ck(this);uh()"><label for="h6">Evening water<span class="tl">16–20 oz</span></label></div>
        <div class="pb"><div class="pf" id="hbar" style="width:0%"></div></div>
        <div class="plbl" id="hlbl">0 of 6 hydration goals · ~0 oz</div>
        <div class="hydro-sync" id="hydro-sync-msg"></div>
      </div>

      <div class="slabel">How are you feeling today?</div>
      <div class="card lav">
        <div class="feel-block">
          <div class="feel-title">Energy level</div>
          <div class="feel-opts">
